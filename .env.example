# Brana Leather Environment Variables
# Copy to .env.local and fill in your real values

# ─── Site ─────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Business (step 1) ────────────────────────────────
NEXT_PUBLIC_BUSINESS_PHONE=0989977058
NEXT_PUBLIC_BUSINESS_EMAIL=batidev01@gmail.com
NEXT_PUBLIC_BUSINESS_ADDRESS=Bishoftu (Seven Lake City), Ethiopia

# ─── Active payment methods (step 3) ──────────────────
# Comma-separated: telebirr,cbe,cod,chapa,stripe
NEXT_PUBLIC_ACTIVE_PAYMENT_METHODS=telebirr,cbe,cod

# Chapa secret — required for live Telebirr & CBE checkout
CHAPA_SECRET_KEY=

# ─── Email / notifications (step 7) ───────────────────
NOTIFICATION_EMAIL=batidev01@gmail.com
EMAIL_FROM=Brana Leather <onboarding@resend.dev>
# Get free key at https://resend.com — without it, emails log to console in dev
RESEND_API_KEY=

# ─── Social (step 8) ──────────────────────────────────
NEXT_PUBLIC_INSTAGRAM_HANDLE=bati_jano
NEXT_PUBLIC_TELEGRAM_HANDLE=CME_1CE
NEXT_PUBLIC_WHATSAPP_NUMBER=251989977058

# ─── Supabase (step 4) — optional for now ─────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Cloudinary (step 4) — optional for now ───────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Stripe (step 3) — disabled until enabled in ACTIVE_PAYMENT_METHODS
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Shipping (step 2) ────────────────────────────────
NEXT_PUBLIC_FREE_SHIPPING_THRESHOLD=10000
NEXT_PUBLIC_SHIPPING_FEE=500

# ─── Analytics (step 6) ───────────────────────────────
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_CLARITY_ID=
